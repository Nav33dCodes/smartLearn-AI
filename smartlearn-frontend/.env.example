# ==========================================
# FRONTEND DEPLOYMENT GUIDE (VERCEL)
# ==========================================
# When deploying to Vercel, go to your Project Settings > Environment Variables
# and add the following variable so your frontend knows where to find the backend:

# VITE_API_URL
# ------------
# Local dev: http://localhost:8000
# Production: Your Railway URL (e.g. https://smartlearn-backend.up.railway.app)

VITE_API_URL=http://localhost:8000
