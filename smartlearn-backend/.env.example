# ==========================================
# BACKEND DEPLOYMENT GUIDE (RAILWAY)
# ==========================================
# 1. CORS & Frontend Linking
# --------------------------
# Set ALLOWED_ORIGINS to your Vercel URL to prevent CORS blocks.
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000"

# Set FRONTEND_URL to your Vercel URL so automated emails point to the real website.
FRONTEND_URL="https://smartlearn.work"

# 2. Security & Database
JWT_SECRET="your_jwt_secret_here"

DATABASE_URL="postgresql://user:password@host:port/dbname"
REDIS_URL="rediss://default:password@host:port"
OPENROUTER_API_KEY="sk-or-v1-..."
GROQ_API_KEY="gsk_..."
GEMINI_API_KEY="AQ..."
TAVILY_API_KEY="tvly-..."
YOUTUBE_API_KEY="AIza..."
# Email Configuration (Resend)
SMTP_EMAIL="noreply@smartlearn.work"
RESEND_API_KEY="re_123456789"